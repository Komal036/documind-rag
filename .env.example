# --- LLM Settings ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.0
OPENAI_MAX_TOKENS=1024
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-small
LLM_PROVIDER=openai

# --- Embedding Settings ---
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=64
EMBEDDING_CACHE_DIR=.model_cache

# --- Vector Store Settings ---
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=vector_store/chroma_db
CHROMA_COLLECTION_NAME=documind_collection
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=documind-index

# --- Chunking Settings ---
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MIN_CHUNK_LENGTH=50

# --- Retrieval Settings ---
RETRIEVAL_TOP_K=20
RERANKING_TOP_N=5
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
SIMILARITY_THRESHOLD=0.3

# --- API Settings ---
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_KEY=dev-api-key-change-in-prod
CORS_ORIGINS=http://localhost:8501
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,docx,txt,md

# --- Logging Settings ---
LOG_LEVEL=INFO
LOG_FORMAT=console
LOG_FILE=logs/documind.log

# --- Environment ---
ENVIRONMENT=development
DEBUG=false